{
  "manifest_version": 3,
  "name": "Pokemon Web Idle",
  "version": "1.0.5",
  "description": "It's an idle battle RPG game in your web browser. Evolve Pokémon, make a build, and have fun!",

  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/Icons/Pokeball.png",
    "32": "assets/Icons/Pokeball.png",
    "48": "assets/Icons/Pokeball.png",
    "128": "assets/Icons/Pokeball.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/Icons/Pokeball.png",
      "32": "assets/Icons/Pokeball.png",
      "48": "assets/Icons/Pokeball.png",
      "128": "assets/Icons/Pokeball.png"
    }
  },
  
    "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "pokemon_db.js",
        "moves_en.js",
        "moves_pt.js",
        "database.js",
        "ui.js",
        "battle.js",
        "engine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*/*.png",
        "assets/Icons/*.png"
      ]
    }
  ]
}
